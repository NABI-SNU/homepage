{
  "name": "homepage",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "prebuild": "pnpm generate:importmap",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "predev": "rm -rf .next/cache && pnpm generate:importmap",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "predev:turbopack": "rm -rf .next/cache && pnpm generate:importmap",
    "dev:turbopack": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbopack",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "db:check:activity-indexes": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" tsx scripts/check-activity-indexes.ts",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:repair": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" tsx scripts/repair-migration-state.ts",
    "migrate:status": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:status",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "prepare": "husky",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "seed:test-accounts": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" tsx scripts/seed-test-accounts.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "typecheck": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit",
    "format:check": "cross-env NODE_OPTIONS=--no-deprecation prettier --check ."
  },
  "dependencies": {
    "@better-auth/passkey": "^1.5.5",
    "@delmaredigital/payload-better-auth": "^0.6.1",
    "@neondatabase/serverless": "^1.0.2",
    "@payloadcms/db-postgres": "3.78.0",
    "@payloadcms/email-nodemailer": "^3.78.0",
    "@payloadcms/live-preview-react": "3.78.0",
    "@payloadcms/next": "3.78.0",
    "@payloadcms/plugin-form-builder": "3.78.0",
    "@payloadcms/plugin-nested-docs": "3.78.0",
    "@payloadcms/plugin-redirects": "3.78.0",
    "@payloadcms/plugin-search": "3.78.0",
    "@payloadcms/plugin-seo": "3.78.0",
    "@payloadcms/richtext-lexical": "3.78.0",
    "@payloadcms/storage-s3": "3.78.0",
    "@payloadcms/ui": "3.80.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@tweenjs/tween.js": "^25.0.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "d3": "^7.9.0",
    "dotenv": "17.3.1",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "0.577.0",
    "myst-parser": "^1.7.0",
    "myst-to-html": "^1.7.0",
    "next": "15.5.10",
    "next-sitemap": "^4.2.3",
    "nodemailer": "^8.0.1",
    "payload": "3.78.0",
    "pg": "^8.19.0",
    "pixi.js": "^8.16.0",
    "plotly.js-dist-min": "^3.4.0",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.2",
    "sharp": "0.34.5",
    "styled-components": "5.3.11",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.2",
    "@types/d3": "^7.4.3",
    "@types/escape-html": "^1.0.2",
    "@types/node": "25.5.0",
    "@types/pg": "^8.18.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.5.10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "28.0.0",
    "lint-staged": "^16.3.2",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "^1.19.10",
      "markdown-it": "^14.1.1",
      "dompurify": "^3.3.2",
      "esbuild": "^0.25.0",
      "fast-xml-parser": "^5.3.8",
      "hono": "^4.12.4",
      "immutable": "^4.3.8",
      "lodash": "^4.17.23",
      "payload>ajv": "^8.18.0"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver",
      "@prisma/engines",
      "prisma"
    ],
    "patchedDependencies": {
      "markdown-it-dollarmath@0.5.0": "patches/markdown-it-dollarmath@0.5.0.patch",
      "myst-to-html@1.7.0": "patches/myst-to-html@1.7.0.patch"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "pnpm exec eslint --max-warnings=0 --no-warn-ignored --fix",
      "pnpm exec prettier --write"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "pnpm exec prettier --write"
    ]
  }
}
