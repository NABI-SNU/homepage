# Database connection string (Postgres)
STORAGE_DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name
# Optional override; defaults to true for neon.tech hosts when unset.
STORAGE_DATABASE_USE_NEON_SERVERLESS=
# Legacy fallback (deprecated): if STORAGE_DATABASE_URL is missing, runtime can still read DATABASE_URL.
DATABASE_URL=
# Optional automatic schema push on server boot. Prefer `false` for shared/prod DBs and use migrations.
PAYLOAD_PUSH_SCHEMA=false
# Optional migration source override. If unset, scripts/migrations.ts uses STORAGE_DATABASE_URL.
SOURCE_DATABASE_URL=
# Optional migration target. scripts/migrations.ts also accepts NEW_STORAGE_DATABASE_URL / NEW_DATABASE_URL.
TARGET_DATABASE_URL=
# Optional client binary overrides for scripts/migrations.ts
PG_DUMP_BIN=
PSQL_BIN=
# Optional: use Dockerized Postgres client tools (helps when local client version mismatches server)
USE_DOCKER_PGTOOLS=false
PGTOOLS_DOCKER_IMAGE=postgres:17

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# BetterAuth configuration
APP_NAME=NABI Labs
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=YOUR_BETTER_AUTH_SECRET
AUTH_TRUSTED_ORIGINS=http://localhost:3000
AUTH_USE_SECURE_COOKIES=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# SMTP configuration (Payload nodemailer adapter)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM_ADDRESS=no-reply@example.com
SMTP_FROM_NAME=NABI Labs
USER_APPROVAL_EMAIL_TO=admin@nabi.org
USER_APPROVAL_TOKEN_SECRET=YOUR_OPTIONAL_APPROVAL_SECRET
USER_APPROVAL_TOKEN_TTL_HOURS=168

# Optional persistent media storage (recommended for production / Vercel)
# Works with AWS S3 and S3-compatible providers like Cloudflare R2.
# Set S3_STORAGE_ENABLED=false to force local storage.
S3_STORAGE_ENABLED=true
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# Public file base URL (R2 custom domain or r2.dev URL) used for browser image URLs
S3_PUBLIC_URL=https://media.example.com
# Optional logical folder key for uploads and generated public URLs (e.g. "webp")
S3_MEDIA_PREFIX=media
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_FORCE_PATH_STYLE=true

# Optional: direct browser uploads (recommended on Vercel for larger files)
# Requires CORS PUT on your bucket for your site domain.
S3_CLIENT_UPLOADS=false
